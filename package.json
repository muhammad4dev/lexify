{
  "name": "lexify",
  "private": true,
  "version": "0.0.1",
  "description": "Headless, plugin-driven Rich Text Editor built on Lexical",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r --filter='!@lexify/e2e' --filter='!@lexify/demo' test",
    "test:e2e": "pnpm --filter @lexify/e2e test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.30.3"
}
