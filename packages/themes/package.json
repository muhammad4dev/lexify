{
  "name": "@lexify/themes",
  "version": "0.0.3",
  "description": "Styling presets for Lexify",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./css/base.css": "./css/base.css"
  },
  "files": [
    "LICENSE",
    "README.md",
    "css",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lexify/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "vitest": "^3.0.9"
  },
  "license": "MIT",
  "homepage": "https://muhammad4dev.github.io/lexify",
  "repository": {
    "type": "git",
    "url": "https://github.com/muhammad4dev/lexify.git",
    "directory": "packages/themes"
  },
  "bugs": {
    "url": "https://github.com/muhammad4dev/lexify/issues"
  }
}
