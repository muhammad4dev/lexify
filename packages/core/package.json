{
  "name": "@lexify/core",
  "version": "0.0.1",
  "description": "Lexify engine abstraction \u2014 no React, no UI",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "lexical": "^0.31.1"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "vitest": "^3.0.9"
  },
  "license": "MIT",
  "homepage": "https://muhammad4dev.github.io/lexify",
  "repository": {
    "type": "git",
    "url": "https://github.com/muhammad4dev/lexify.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/muhammad4dev/lexify/issues"
  }
}
