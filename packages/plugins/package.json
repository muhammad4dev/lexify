{
  "name": "@lexify/plugins",
  "version": "0.0.1",
  "description": "All Lexify plugins — tree-shakeable, single install",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lexify/core": "workspace:*",
    "@lexical/history": "^0.31.1",
    "@lexical/link": "^0.31.1",
    "@lexical/list": "^0.31.1",
    "@lexical/rich-text": "^0.31.1",
    "@lexical/selection": "^0.31.1",
    "lexical": "^0.31.1"
  },
  "peerDependencies": {
    "lexical": "^0.31.1"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "vitest": "^3.0.9"
  }
}
