{
  "name": "@lexify/react",
  "version": "0.0.2",
  "description": "React bindings for Lexify",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lexify/core": "workspace:*",
    "@lexical/react": "^0.31.1",
    "lexical": "^0.31.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.0",
    "jsdom": "^26.0.0",
    "react": "^19.1.0",
    "tsup": "^8.4.0",
    "vitest": "^3.0.9"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "license": "MIT",
  "homepage": "https://muhammad4dev.github.io/lexify",
  "repository": {
    "type": "git",
    "url": "https://github.com/muhammad4dev/lexify.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/muhammad4dev/lexify/issues"
  }
}
