{
  "name": "@lexify/ui",
  "version": "0.0.1",
  "description": "Optional visual components for Lexify",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@lexify/core": "workspace:*",
    "@lexify/react": "workspace:*",
    "@lexify/plugin-utils": "workspace:*",
    "@lexify/plugin-history": "workspace:*",
    "@lexify/plugin-bold": "workspace:*",
    "@lexify/plugin-italic": "workspace:*",
    "@lexify/plugin-underline": "workspace:*",
    "@lexify/plugin-strikethrough": "workspace:*",
    "@lexify/plugin-code": "workspace:*",
    "@lexify/plugin-heading": "workspace:*",
    "@lexify/plugin-text-align": "workspace:*",
    "@lexify/plugin-list": "workspace:*",
    "@lexify/plugin-font-size": "workspace:*",
    "@lexify/plugin-font-color": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.0",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.4.0",
    "vitest": "^3.0.9"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  }
}
